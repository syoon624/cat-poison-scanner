# ============================================
# PurrfectScan Backend 환경 변수 설정 파일
# 이 파일을 복사하여 .env 파일을 생성하세요
# cp .env.example .env
# ============================================

# 서버 포트 설정
PORT=5000

# MongoDB 연결 문자열
# 로컬: mongodb://localhost:27017/purrfectscan
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/purrfectscan
MONGODB_URI=mongodb://localhost:27017/purrfectscan

# Google Cloud Vision API 키
# https://console.cloud.google.com 에서 발급
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=your_openai_api_key_here

# Node 환경 (development / production)
NODE_ENV=development
