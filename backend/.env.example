# ============================================
# PurrfectScan Backend 환경 변수 설정 파일
# 이 파일을 복사하여 .env 파일을 생성하세요
#   Windows: copy .env.example .env
#   Mac/Linux: cp .env.example .env
# ============================================

# 서버 포트 설정 (로컬 개발 시 5000, Render.com은 자동 할당)
PORT=5000

# MongoDB Atlas 연결 문자열 (프로덕션 DB - 이미 시드 데이터 삽입 완료)
# ⚠️ 비밀번호에 특수문자(!@#)가 포함된 경우 URL 인코딩 필수
#   ! → %21, @ → %40, # → %23
# 클러스터: cluster0.asxy82g.mongodb.net / DB명: purrfectscan
MONGODB_URI=mongodb+srv://syoon624_db_user:<URL_ENCODED_PASSWORD>@cluster0.asxy82g.mongodb.net/purrfectscan?retryWrites=true&w=majority&appName=Cluster0

# Google Cloud Vision API 키
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# Cloud Vision API 활성화 필요
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# OpenAI API 키 (gpt-4o-mini 사용, $10 충전 완료 상태)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=your_openai_api_key_here

# Node 환경 (development / production)
NODE_ENV=development
